{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["aizorix", "screenshot", "ingest"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Aizorix — Screenshot Pipeline",
  "uid": "aizorix-screenshot",
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Ingest Success Ratio (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.97 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(screenshot_ingest_total{result=\"success\"}[5m])) / clamp_min(sum(rate(screenshot_ingest_total[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Uploads / sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(screenshot_ingest_total[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Active Work Sessions",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "sum(worksession_active)", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Flagged (fraud) rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "sum(rate(screenshot_flagged_total[15m])) / clamp_min(sum(rate(screenshot_ingest_total[15m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ingest Outcomes",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 30 } } },
      "targets": [
        {
          "expr": "sum by (result) (rate(screenshot_ingest_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ingest Failure Reasons",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20 } } },
      "targets": [
        {
          "expr": "sum by (reason) (rate(screenshot_ingest_total{result=\"failure\"}[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Upload Latency (p50/p95/p99)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(screenshot_upload_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(screenshot_upload_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(screenshot_upload_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "S3 Object Write Errors",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum by (op) (rate(s3_operation_errors_total{bucket=\"aizorix-screenshots\"}[5m]))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ingest Kafka Consumer Lag (screenshot.ingested)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum by (consumergroup) (kafka_consumergroup_lag{topic=~\"screenshot.*\"})",
          "legendFormat": "{{consumergroup}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Screenshot Service Errors (Loki)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none" },
      "targets": [
        {
          "expr": "{service=\"screenshot\"} | json | level=\"error\"",
          "refId": "A"
        }
      ]
    }
  ]
}
