# ── Copy to .env.local for local dev. NEVER commit real secrets. ──

# Public base URL the browser uses for API calls. In dev this points at the
# Next.js rewrite proxy (/api/gateway) so httpOnly refresh cookies stay
# same-origin. In prod set it to the gateway/BFF origin.
NEXT_PUBLIC_API_BASE_URL=/api/gateway

# Server-only: real gateway origin that next.config rewrites proxy to.
API_GATEWAY_URL=http://localhost:8080

# Public site URL (used for canonical/OG metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe publishable key (client-side Elements). Test key in dev.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Realtime messaging websocket endpoint.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/v1/messaging/ws

# Feature flags
NEXT_PUBLIC_ENABLE_DEVTOOLS=true
