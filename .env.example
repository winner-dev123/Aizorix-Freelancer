# ── Copy to .env for local dev. NEVER commit real secrets. ──

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aizorix
POSTGRES_PASSWORD=aizorix_dev
POSTGRES_DB=aizorix
DATABASE_URL=postgres://aizorix:aizorix_dev@localhost:5432/aizorix?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Kafka (Redpanda in dev)
KAFKA_BROKERS=localhost:19092

# Object storage (MinIO in dev, S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_SCREENSHOTS=aizorix-screenshots
S3_FORCE_PATH_STYLE=true

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Auth / crypto (dev values — replace via Secrets Manager in prod)
JWT_ACCESS_PRIVATE_KEY_PEM=./services/auth/testdata/ec_private.pem
JWT_ACCESS_PUBLIC_KEY_PEM=./services/auth/testdata/ec_public.pem
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=720h
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2

# Envelope encryption (dev: local master key; prod: AWS KMS key ARN)
KMS_MODE=local
KMS_LOCAL_MASTER_KEY=ZGV2LW9ubHktMzItYnl0ZS1tYXN0ZXIta2V5LTEyMzQ1Ng==
KMS_KEY_ARN=

# Stripe (test keys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=debug
ENVIRONMENT=local
